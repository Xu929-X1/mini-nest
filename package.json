{
  "name": "mini-nest",
  "version": "1.0.4",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint src/**/*.ts",
    "bff-example": "npx ts-node src/examples/bff-examples/app.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "benchmark": "npx ts-node benchmark/run.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bff",
    "backend",
    "framework",
    "nestjs",
    "typescript",
    "decorators",
    "dependency-injection",
    "di",
    "aop",
    "cache",
    "retry",
    "timeout",
    "circuit-breaker",
    "guards",
    "interceptors",
    "express",
    "fastify"
  ],
  "author": "Xu929-X1",
  "license": "MIT",
  "description": "A lightweight, NestJS-inspired BFF (Backend-for-Frontend) framework for Node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xu929-X1/mini-nest"
  },
  "bugs": {
    "url": "https://github.com/Xu929-X1/mini-nest/issues"
  },
  "homepage": "https://github.com/Xu929-X1/mini-nest#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "undici": "^7.22.0"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.0",
    "express": "^4.18.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.11",
    "@types/autocannon": "^7.12.7",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autocannon": "^8.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  }
}